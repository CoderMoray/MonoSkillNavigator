# file keeps the existing local JSON registry. postgres enables PostgreSQL.
REGISTRY_STORE=postgres

# PostgreSQL registry store
POSTGRES_PORT=15432
DATABASE_URL=postgres://skill_platform:skill_platform@127.0.0.1:15432/skill_platform

# Optional MinIO artifact storage. Set MINIO_ENABLED=true to store skill snapshots in MinIO.
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=skill_platform
MINIO_SECRET_KEY=skill_platform_secret
MINIO_BUCKET=skill-artifacts

# Web -> API
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
